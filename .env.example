# StarCruiser environment configuration — copy to ".env" and fill in.
# (Both the Python pipeline and the R/Shiny dashboard read these.)

# --- Paths -----------------------------------------------------------------
# DATA_ROOT: where the project READS source/input data from. Point this at a
# directory laid out like a FRED/BEA/Census API export (see data/MANIFEST.md).
DATA_ROOT=data

# OUTPUT_ROOT: where the project WRITES its own outputs (catalogs, clusters,
# realtime feeds, quality reports, etc.).
OUTPUT_ROOT=outputs

# PIPELINE_ROOT (optional): base for prepared data-pipeline outputs consumed by
# the Plotly Dash app (Dashboard/app.py). Defaults to Technical/pipeline.
# PIPELINE_ROOT=Technical/pipeline

# --- API keys (all free; bring your own — see README "API keys") -----------
# FRED:   https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
# Census: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=
# BEA:    https://apps.bea.gov/API/signup/
BEA_API_KEY=
